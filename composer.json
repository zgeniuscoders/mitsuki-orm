{
    "name": "mitsuki/tsuki-orm",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Tsuki\\": "src/",
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Zgeniuscoders",
            "email": "zgeniuscoders@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "doctrine/orm": "^3",
        "doctrine/dbal": "^4",
        "symfony/cache": "^7"
    },
    "require-dev": {
        "pestphp/pest": "^4.4"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}